          "before_after.before_node" : "",
          "enableFlowAcpControl" : true,
          "select_statement" : "(SELECT EMPLOYEE_CODE, COALESCE(MAX(SUMMARY_DATE), TIMESTAMP('1900-01-01 00:00:00')) MAX_DATE,\n\nCOALESCE(TIMESTAMPDIFF(16,\n\nCHAR(MAX(SUMMARY_DATE) - MIN(SUMMARY_DATE)) ), 0) as Period_Total_days,\n\nCOALESCE(MIN(SALARY), 0) Starting_salary,\n\nCOALESCE(MAX(SALARY), 0) Ending_SALARY,\n\nCOALESCE(MAX(SALARY) - MIN(SALARY), 0) increase,\n\nCOALESCE(SUM(CASE WHEN PAY_INCREASE = 0 THEN 0 ELSE 1 END), 0) nb_increases,\n\nCOALESCE(SUM(BONUS * SALARY), 0) BONUS,\n\nCOALESCE(SUM(CASE WHEN BONUS = 0 THEN 0 ELSE 1 END), 0) nb_bonus,\n\nCOALESCE(SUM(VACATION_DAYS_TAKEN), 0) VACATION_DAYS_TAKEN,\n\nCOALESCE(SUM(SICK_DAYS_TAKEN), 0) SICK_DAYS_TAKEN\n\nFROM EMPLOYEE.EMPLOYEE_SUMMARY E2\n\nWHERE (SUMMARY_DATE >= '#Start_Year#-01-01 00:00:00'\n\nAND SUMMARY_DATE < '#End_Year#-01-01 00:00:00')\n\nGROUP BY EMPLOYEE_CODE)",
