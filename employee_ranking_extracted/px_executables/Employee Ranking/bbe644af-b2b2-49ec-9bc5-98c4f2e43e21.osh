FROM EMPLOYEE.EMPLOYEE EMP LEFT OUTER JOIN

(SELECT RK.*

FROM EMPLOYEE.RANKING_RESULTS RK,

(SELECT TB0.EMPLOYEE_CODE,

MAX(TB0.RANKING_DATE) RANKING_DATE

FROM EMPLOYEE.RANKING_RESULTS TB0

WHERE RANKING_DATE < \'[&"End_Year"]-01-01 00:00:00\'

GROUP BY TB0.EMPLOYEE_CODE

) TB1

WHERE RK.EMPLOYEE_CODE = TB1.EMPLOYEE_CODE

AND RK.RANKING_DATE = TB1.RANKING_DATE) RK1

ON EMP.EMPLOYEE_CODE = RK1.EMPLOYEE_CODE

)]]></select_statement><before_sql type=\'string\'><fail_on_error_before_sql type=\'bool\'><![CDATA[1]]></fail_on_error_before_sql></before_sql><node_number type=\'int\'><![CDATA[0]]></node_number><read_mode type=\'int\'><![CDATA[2]]></read_mode><decimal_rounding_mode type=\'int\'><![CDATA[2]]></decimal_rounding_mode><default_max_string_binary_precision type=\'int\'><![CDATA[20000]]></default_max_string_binary_precision><generate_unicode_columns type=\'bool\'><![CDATA[0]]></generate_unicode_columns><after_sql type=\'string\'><fail_on_error_after_sql type=\'bool\'><![CDATA[1]]></fail_on_error_after_sql></after_sql><node_count type=\'int\'><![CDATA[1]]></node_count><connector_name type=\'string\'><![CDATA[dashdb]]></connector_name><UserClassName type=\'string\'><![CDATA[com.ibm.iis.cc.genericscapi.GenericSCAPI]]></UserClassName><ConnectorOtherOptions type=\'string\'><![CDATA[-Dcom.ibm.tools.attach.enable=no -Dcom.ibm.is.cc.options=noisfjars]]></ConnectorOtherOptions></Usage></Properties>'
