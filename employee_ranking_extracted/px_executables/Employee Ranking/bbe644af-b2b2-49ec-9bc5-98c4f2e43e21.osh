TIMESTAMPDIFF(16,

CHAR(MAX(SUMMARY_DATE) - MIN(SUMMARY_DATE)) ) as Period_Total_days,

MIN(SALARY) Starting_salary,

MAX(SALARY) Ending_SALARY,

MAX(SALARY) - MIN(SALARY) increase,

SUM(CASE WHEN PAY_INCREASE = 0 THEN 0 ELSE 1 END) nb_increases,

SUM(BONUS * SALARY) BONUS,

SUM(CASE WHEN BONUS = 0 THEN 0 ELSE 1 END) nb_bonus,

SUM(VACATION_DAYS_TAKEN) VACATION_DAYS_TAKEN,

SUM(SICK_DAYS_TAKEN) SICK_DAYS_TAKEN

FROM EMPLOYEE.EMPLOYEE_SUMMARY E2

WHERE (SUMMARY_DATE >= \'[&"Start_Year"]-01-01 00:00:00\'

AND SUMMARY_DATE < \'[&"End_Year"]-01-01 00:00:00\')

GROUP BY EMPLOYEE_CODE)]]></select_statement><before_sql type=\'string\'><fail_on_error_before_sql type=\'bool\'><![CDATA[1]]></fail_on_error_before_sql></before_sql><node_number type=\'int\'><![CDATA[0]]></node_number><read_mode type=\'int\'><![CDATA[2]]></read_mode><decimal_rounding_mode type=\'int\'><![CDATA[2]]></decimal_rounding_mode><default_max_string_binary_precision type=\'int\'><![CDATA[20000]]></default_max_string_binary_precision><generate_unicode_columns type=\'bool\'><![CDATA[0]]></generate_unicode_columns><after_sql type=\'string\'><fail_on_error_after_sql type=\'bool\'><![CDATA[1]]></fail_on_error_after_sql></after_sql><node_count type=\'int\'><![CDATA[1]]></node_count><connector_name type=\'string\'><![CDATA[dashdb]]></connector_name><UserClassName type=\'string\'><![CDATA[com.ibm.iis.cc.genericscapi.GenericSCAPI]]></UserClassName><ConnectorOtherOptions type=\'string\'><![CDATA[-Dcom.ibm.tools.attach.enable=no -Dcom.ibm.is.cc.options=noisfjars]]></ConnectorOtherOptions></Usage></Properties>'
